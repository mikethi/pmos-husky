c56427f7b0576a4e80c43b5a264589be77e725a3caca9f2463ec11afb7b30ef359ca567c649435a9f68966d63e434304acff13f8cb8218f76757018958b7f28e  husky_defconfig
fcc6e102e4aa75529eff19e5630f901d06b56e6912d35ac26ba2d1e731357eb16ec63cf678f2cad119e0621c608cda6d864af81c0f1968d30b84d75a054bcb38  USAGE.md
"
