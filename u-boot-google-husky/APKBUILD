# Reference: <https://postmarketos.org/devicepkg>
# U-Boot board config for Google Pixel 8 Pro (husky, Tensor G3 / Zuma SoC).
# Ships the board header and defconfig so any user can drop them into an
# upstream U-Boot tree and build.  See USAGE.md for quick-start instructions.
pkgname=u-boot-google-husky
pkgdesc="U-Boot board config and defconfig for Google Pixel 8 Pro (husky)"
pkgver=1
pkgrel=0
url="https://github.com/u-boot/u-boot"
license="GPL-2.0-only"
arch="aarch64"
options="!check !archcheck"

source="
	husky.h
	husky_defconfig
	USAGE.md
"

package() {
	# Board header -- copy to include/configs/husky.h inside a U-Boot tree
	install -Dm644 "$srcdir/husky.h" \
		"$pkgdir/usr/share/u-boot-google-husky/include/configs/husky.h"

	# Kconfig defconfig -- copy to configs/husky_defconfig inside a U-Boot tree
	install -Dm644 "$srcdir/husky_defconfig" \
		"$pkgdir/usr/share/u-boot-google-husky/configs/husky_defconfig"

	# Usage instructions
	install -Dm644 "$srcdir/USAGE.md" \
		"$pkgdir/usr/share/u-boot-google-husky/USAGE.md"
}

sha512sums="
